// VIGISCAM Backend — Prisma schema
// Phase 0: AuditLog. Phase 1A: identity, tenancy, roles, auth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── Enums ────────────────────────────

/// Tenant categories (PDF §8 "Tenant Types").
enum TenantType {
  PUBLIC
  PERSONAL
  FAMILY
  BANK
  PLATFORM
  INVESTIGATOR
  AGENCY
  ENTERPRISE
  INTERNAL
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DISABLED
}

/// A user's role within a specific tenant (PDF §7 "Role-Based User Architecture").
enum MembershipRole {
  // Consumer
  INDIVIDUAL
  FAMILY_GUARDIAN
  PROTECTED_USER
  // Institutional
  BANK_ADMIN
  BANK_ANALYST
  PLATFORM_ADMIN
  PLATFORM_MODERATOR
  INVESTIGATOR
  AGENCY_ANALYST
  ENTERPRISE_ADMIN
  // Internal VIGISCAM
  SUPER_ADMIN
  REVIEWER
  COMPLIANCE_OFFICER
  SUPPORT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

// ──────────────────────────── Models ───────────────────────────

/// An isolation boundary. Every tenant-scoped record carries a tenantId.
model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  type      TenantType
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships Membership[]
  devices     Device[]
  sessions    Session[]

  @@index([type])
  @@map("tenants")
}

/// A global user account. Access to a tenant is granted via a Membership.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String
  fullName     String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  devices       Device[]
  sessions      Session[]

  @@map("users")
}

/// Links a user to a tenant with a role — the unit of RBAC.
model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  tenantId  String           @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(ACTIVE)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

/// A hashed, rotating refresh token. The raw token is never stored.
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ───────────────────── Devices & sessions (Phase 1B) ─────────────────────

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BROWSER_EXTENSION
  OTHER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

/// An enrolled device belonging to a user (desktop agent, mobile app, extension).
model Device {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @db.Uuid
  tenantId   String       @db.Uuid
  name       String
  type       DeviceType
  platform   String?
  status     DeviceStatus @default(ACTIVE)
  trusted    Boolean      @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@index([tenantId])
  @@map("devices")
}

/// One protected session type, discriminated by `type` (call/video/remote/etc).
enum SessionType {
  LIVE_CALL
  VIDEO
  REMOTE_DESKTOP
  BROWSER
  SCREEN_SHARE
}

enum SessionStatus {
  ACTIVE
  ENDED
  FLAGGED
}

/// A monitored session. Risk and FREEZEGUARD/A1SCAMSHIELD telemetry attach here.
model Session {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  tenantId  String        @db.Uuid
  deviceId  String?       @db.Uuid
  type      SessionType
  status    SessionStatus @default(ACTIVE)
  riskScore Int           @default(0)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  events SessionEvent[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@map("sessions")
}

/// A timestamped event within a session — an evidence marker for later phases.
model SessionEvent {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @db.Uuid
  type      String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_events")
}

// ───────────────────── Evidence Vault (Phase 1C) ─────────────────────

/// Tamper-evident, hash-chained evidence log (PDF §28.11 / §35). Append-only:
/// each event chains to the previous one in its tenant chain via SHA-256, so
/// any later alteration is detectable. Deliberately has NO foreign keys — the
/// evidence record must outlive the entities it describes (retention / legal
/// hold). System-level events use a null tenant chain.
model EvidenceEvent {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String?  @db.Uuid
  sequence         Int
  actorId          String?  @db.Uuid
  actorType        String?
  entityType       String
  entityId         String
  eventType        String
  eventDescription String
  metadata         Json?
  ipAddress        String?
  deviceId         String?
  previousHash     String?
  eventHash        String
  occurredAt       DateTime
  createdAt        DateTime @default(now())

  @@unique([tenantId, sequence])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([eventType])
  @@map("evidence_events")
}

/// Foundational, cross-cutting audit table. Every sensitive action writes here
/// (see docs/05-GUARDRAILS-HARDENING.md §9).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorType  String?
  action     String
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

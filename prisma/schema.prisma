// VIGISCAM Backend — Prisma schema
// Phase 0: AuditLog. Phase 1A: identity, tenancy, roles, auth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── Enums ────────────────────────────

/// Tenant categories (PDF §8 "Tenant Types").
enum TenantType {
  PUBLIC
  PERSONAL
  FAMILY
  BANK
  PLATFORM
  INVESTIGATOR
  AGENCY
  ENTERPRISE
  INTERNAL
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DISABLED
}

/// A user's role within a specific tenant (PDF §7 "Role-Based User Architecture").
enum MembershipRole {
  // Consumer
  INDIVIDUAL
  FAMILY_GUARDIAN
  PROTECTED_USER
  // Institutional
  BANK_ADMIN
  BANK_ANALYST
  PLATFORM_ADMIN
  PLATFORM_MODERATOR
  INVESTIGATOR
  AGENCY_ANALYST
  ENTERPRISE_ADMIN
  // Internal VIGISCAM
  SUPER_ADMIN
  REVIEWER
  COMPLIANCE_OFFICER
  SUPPORT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

// ──────────────────────────── Models ───────────────────────────

/// An isolation boundary. Every tenant-scoped record carries a tenantId.
model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  type      TenantType
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  memberships            Membership[]
  devices                Device[]
  sessions               Session[]
  riskEvents             RiskEvent[]
  freezeLockEvents       FreezeLockEvent[]
  alerts                 Alert[]
  trustedContacts        TrustedContact[]
  guardianLinks          GuardianLink[]
  partnerApiKeys         PartnerApiKey[]
  webhookSubscriptions   WebhookSubscription[]
  evidenceExportBundles  EvidenceExportBundle[]
  agencyFeeds            AgencyFeed[]

  @@index([type])
  @@map("tenants")
}

/// A global user account. Access to a tenant is granted via a Membership.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String
  fullName     String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships      Membership[]
  refreshTokens    RefreshToken[]
  devices          Device[]
  sessions         Session[]
  riskEvents       RiskEvent[]
  freezeLockEvents FreezeLockEvent[]
  alerts           Alert[]
  trustedContacts  TrustedContact[]
  guardianLinks    GuardianLink[]   @relation("GuardianLinks")
  protectedByLinks GuardianLink[]   @relation("ProtectedByLinks")

  @@map("users")
}

/// Links a user to a tenant with a role — the unit of RBAC.
model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  tenantId  String           @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(ACTIVE)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

/// A hashed, rotating refresh token. The raw token is never stored.
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ───────────────────── Devices & sessions (Phase 1B) ─────────────────────

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BROWSER_EXTENSION
  OTHER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

/// An enrolled device belonging to a user (desktop agent, mobile app, extension).
model Device {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @db.Uuid
  tenantId   String       @db.Uuid
  name       String
  type       DeviceType
  platform   String?
  status     DeviceStatus @default(ACTIVE)
  trusted    Boolean      @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@index([tenantId])
  @@map("devices")
}

/// One protected session type, discriminated by `type` (call/video/remote/etc).
enum SessionType {
  LIVE_CALL
  VIDEO
  REMOTE_DESKTOP
  BROWSER
  SCREEN_SHARE
}

enum SessionStatus {
  ACTIVE
  ENDED
  FLAGGED
}

/// A monitored session. Risk and FREEZEGUARD/A1SCAMSHIELD telemetry attach here.
model Session {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  tenantId  String        @db.Uuid
  deviceId  String?       @db.Uuid
  type      SessionType
  status    SessionStatus @default(ACTIVE)
  riskScore Int           @default(0)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user                    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device                  Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  events                  SessionEvent[]
  authenticityChecks      AuthenticityCheck[]
  fraudJourneyAssessments FraudJourneyAssessment[]
  victimStateAssessments  VictimStateAssessment[]
  predictedNextMoves      PredictedNextMove[]
  riskFusionAssessments   RiskFusionAssessment[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@map("sessions")
}

/// A timestamped event within a session — an evidence marker for later phases.
model SessionEvent {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @db.Uuid
  type      String
  detail    String?
  metadata  Json?
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_events")
}

// ────────────── Risk, intervention & alerts (Phase 1D) ──────────────

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskEventStatus {
  OPEN
  INTERVENING
  RESOLVED
  DISMISSED
}

enum RiskModuleSource {
  RISK_FUSION
  FREEZEGUARD
  A1SCAMSHIELD
  GUARDIAN_PAUSE
  SCAMHOLD
  GIFTCARDGUARD
  WALLETGUARD
  CLAIMVERIFY
  MANUAL
}

/// A scored unit of suspicious activity. Every scam signal becomes a RiskEvent;
/// a serious one can trigger intervention, alerts and evidence (PDF §23, §27).
model RiskEvent {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  userId            String           @db.Uuid
  sessionId         String?          @db.Uuid
  moduleSource      RiskModuleSource
  eventType         String
  riskScore         Int
  riskLevel         RiskLevel
  status            RiskEventStatus  @default(OPEN)
  triggerReason     String
  recommendedAction String
  detectedSignals   String[]
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  freezeLockEvents FreezeLockEvent[]
  alerts           Alert[]

  @@index([userId])
  @@index([tenantId])
  @@index([riskLevel])
  @@index([status])
  @@map("risk_events")
}

enum FreezeLockStatus {
  EXECUTED
  CLEARED
  FAILED
}

/// An emergency-intervention record (PDF §21). Created when a critical risk
/// event — or an explicit emergency action — fires FreezeLock.
model FreezeLockEvent {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @db.Uuid
  userId      String           @db.Uuid
  riskEventId String?          @db.Uuid
  sessionId   String?          @db.Uuid
  trigger     String
  actions     String[]
  status      FreezeLockStatus @default(EXECUTED)
  executedAt  DateTime         @default(now())
  createdAt   DateTime         @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  riskEvent RiskEvent? @relation(fields: [riskEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@map("freezelock_events")
}

enum AlertSeverity {
  INFO
  WARNING
  HIGH
  CRITICAL
}

/// A user-facing alert. Phase 1D persists alerts (in-app); email/SMS/push/
/// WebSocket delivery channels are wired in later phases.
model Alert {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  userId      String        @db.Uuid
  riskEventId String?       @db.Uuid
  type        String
  severity    AlertSeverity
  title       String
  message     String
  readAt      DateTime?
  createdAt   DateTime      @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  riskEvent RiskEvent? @relation(fields: [riskEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([readAt])
  @@map("alerts")
}

// ────────────── Family, guardian & consent (Phase 1F) ──────────────

enum TrustedContactStatus {
  ACTIVE
  INACTIVE
}

/// A person a user trusts to be alerted or to review risky actions. Not
/// necessarily a VIGISCAM account — just contact details owned by the user.
model TrustedContact {
  id                        String               @id @default(uuid()) @db.Uuid
  tenantId                  String               @db.Uuid
  userId                    String               @db.Uuid
  fullName                  String
  relationship              String?
  email                     String?
  phone                     String?
  status                    TrustedContactStatus @default(ACTIVE)
  canReceiveAlerts          Boolean              @default(true)
  canApproveHighRiskActions Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("trusted_contacts")
}

enum GuardianLinkStatus {
  PENDING
  ACTIVE
  DECLINED
  REVOKED
}

/// A guardian↔protected-user monitoring relationship. Monitoring is strictly
/// consent-based: it is ACTIVE only after the protected user grants consent,
/// and the protected user can revoke it at any time (PDF §9.2 — non-negotiable).
model GuardianLink {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  guardianUserId   String             @db.Uuid
  protectedUserId  String             @db.Uuid
  status           GuardianLinkStatus @default(PENDING)
  scope            String[]
  requestedAt      DateTime           @default(now())
  consentGrantedAt DateTime?
  consentRevokedAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  guardian      User   @relation("GuardianLinks", fields: [guardianUserId], references: [id], onDelete: Cascade)
  protectedUser User   @relation("ProtectedByLinks", fields: [protectedUserId], references: [id], onDelete: Cascade)
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([guardianUserId, protectedUserId])
  @@index([guardianUserId])
  @@index([protectedUserId])
  @@map("guardian_links")
}

// ───────────────────── Evidence Vault (Phase 1C) ─────────────────────

/// Tamper-evident, hash-chained evidence log (PDF §28.11 / §35). Append-only:
/// each event chains to the previous one in its tenant chain via SHA-256, so
/// any later alteration is detectable. Deliberately has NO foreign keys — the
/// evidence record must outlive the entities it describes (retention / legal
/// hold). System-level events use a null tenant chain.
model EvidenceEvent {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String?  @db.Uuid
  sequence         Int
  actorId          String?  @db.Uuid
  actorType        String?
  entityType       String
  entityId         String
  eventType        String
  eventDescription String
  metadata         Json?
  ipAddress        String?
  deviceId         String?
  previousHash     String?
  eventHash        String
  occurredAt       DateTime
  createdAt        DateTime @default(now())

  @@unique([tenantId, sequence])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([eventType])
  @@map("evidence_events")
}

/// Foundational, cross-cutting audit table. Every sensitive action writes here
/// (see docs/05-GUARDRAILS-HARDENING.md §9).
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorType  String?
  action     String
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ────────── ScamPulse Intelligence Foundation (Phase 2) ──────────

enum IndicatorType {
  PHONE
  EMAIL
  DOMAIN
  URL
  CRYPTO_WALLET
  SCAM_PHRASE
  FAKE_COMPANY
  SOCIAL_PROFILE
  OTHER
}

enum SignalSourceType {
  USER_REPORT
  PARTNER_REPORT
  BANK_REPORT
  INVESTIGATOR
  GOVERNMENT_ADVISORY
  PUBLIC_WEB
  INTERNAL
}

/// Scam-signal lifecycle (PDF §11). A signal is never automatically verified.
enum ScamSignalStatus {
  UNVERIFIED_REPORT
  SUSPICIOUS_SIGNAL
  PATTERN_MATCH
  UNDER_REVIEW
  HIGH_RISK_INDICATOR
  VERIFIED_SCAM_INTELLIGENCE
  PUBLIC_SAFE_ALERT
  ARCHIVED
  REJECTED
}

/// Registry-entry lifecycle (PDF §15). Only PUBLISHED entries are public.
/// These are INTERNAL statuses — they are never shown on a public surface.
enum RegistryEntryStatus {
  CANDIDATE
  UNDER_REVIEW
  APPROVED_PUBLIC_SAFE
  PUBLISHED
  REJECTED
  ARCHIVED
}

/// The ONLY classifications allowed on a public-facing registry entry
/// (PDF §38, docs/04 §3). Status-based, non-accusatory language — never a
/// direct accusation of a named person or business.
enum RegistryPublicStatus {
  VERIFIED_MALICIOUS
  HIGH_RISK_VERIFIED
  OFFICIALLY_REPORTED
  TAKEDOWN_CONFIRMED
}

enum ReviewQueueStatus {
  PENDING
  IN_REVIEW
  COMPLETED
}

/// Reference table of scam categories (PDF §12 / §28.4). Seeded by migration.
model ScamCategory {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  riskWeight  Int      @default(50)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("scam_categories")
}

/// How much a class of source is trusted (PDF §28.3 / §31). Seeded by migration.
model SourceReliabilityProfile {
  id                       String   @id @default(uuid()) @db.Uuid
  sourceType               String   @unique
  baseReliabilityScore     Int
  requiresReview           Boolean  @default(true)
  allowedForPublicRegistry Boolean  @default(false)
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("source_reliability_profiles")
}

/// A suspicious indicator submitted or ingested into VIGISCAM (PDF §28.1).
/// Private by default — never automatically public.
model ScamSignal {
  id                     String           @id @default(uuid()) @db.Uuid
  tenantId               String?          @db.Uuid
  submittedByUserId      String?          @db.Uuid
  sourceType             SignalSourceType
  sourceName             String?
  category               String?
  indicatorType          IndicatorType
  indicatorValue         String
  normalizedIndicator    String
  description            String?
  rawText                String?
  reportCount            Int              @default(1)
  confidenceScore        Int              @default(0)
  sourceReliabilityScore Int              @default(0)
  evidenceStrengthScore  Int              @default(0)
  recencyScore           Int              @default(0)
  status                 ScamSignalStatus @default(UNVERIFIED_REPORT)
  geography              String?
  firstSeen              DateTime         @default(now())
  lastSeen               DateTime         @default(now())
  clusterId              String?          @db.Uuid
  publicSafeCandidate    Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  evidence          ScamSignalEvidence[]
  cluster           ScamCluster?         @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  embedding         SignalEmbedding?
  similaritiesA     SignalSimilarity[]   @relation("SimilarityA")
  similaritiesB     SignalSimilarity[]   @relation("SimilarityB")
  osintEnrichments  OsintEnrichment[]

  @@index([normalizedIndicator])
  @@index([indicatorType])
  @@index([status])
  @@index([tenantId])
  @@index([clusterId])
  @@map("scam_signals")
}

/// Evidence attached to a scam signal (PDF §28.2).
model ScamSignalEvidence {
  id                String   @id @default(uuid()) @db.Uuid
  signalId          String   @db.Uuid
  evidenceType      String
  evidenceSummary   String?
  fileUrl           String?
  sourceUrl         String?
  hashValue         String?
  submittedByUserId String?  @db.Uuid
  createdAt         DateTime @default(now())

  signal ScamSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@map("scam_signal_evidence")
}

/// A public-safe scam-intelligence item (PDF §28.8). Public only when PUBLISHED.
model RegistryEntry {
  id                  String              @id @default(uuid()) @db.Uuid
  indicatorType       IndicatorType
  indicatorValue      String
  normalizedIndicator String
  category            String
  status              RegistryEntryStatus @default(CANDIDATE)
  publicStatus        RegistryPublicStatus?
  confidenceScore     Int                 @default(0)
  publicSafeSummary   String
  recommendedAction   String?
  firstSeen           DateTime?
  lastSeen            DateTime?
  evidenceCount       Int                 @default(0)
  sourceSignalId      String?             @db.Uuid
  approvedByUserId    String?             @db.Uuid
  approvedAt          DateTime?
  publishedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  appeals   RegistryAppeal[]
  takedowns TakedownRequest[]

  @@index([normalizedIndicator])
  @@index([indicatorType])
  @@index([status])
  @@map("registry_entries")
}

/// The internal review queue gating intelligence on its way to the public
/// registry (PDF §28.9). No raw report ever becomes public without review.
model RegistryReviewQueue {
  id               String            @id @default(uuid()) @db.Uuid
  signalId         String?           @db.Uuid
  registryEntryId  String?           @db.Uuid
  reviewStatus     ReviewQueueStatus @default(PENDING)
  publicSafe       Boolean           @default(false)
  assignedToUserId String?           @db.Uuid
  reviewNotes      String?
  decision         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([reviewStatus])
  @@map("registry_review_queue")
}

/// The stored result of a consumer scam check (PDF §28.10).
model ScamCheckResult {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String?       @db.Uuid
  tenantId        String?       @db.Uuid
  inputType       IndicatorType
  inputValue      String
  normalizedInput String
  riskScore       Int
  riskLevel       RiskLevel
  category        String?
  matchedRegistry Json?
  matchedSignals  Json?
  suggestedAction String
  savedToEvidence Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([normalizedInput])
  @@map("scam_check_results")
}

// ────────── Registry Governance — corrections & appeals (Phase 3C) ──────────

/// What a contesting party is asking for (PDF §27).
enum RegistryAppealType {
  CORRECTION // a listed detail is inaccurate
  REMOVAL // the indicator should not be listed at all
  OWNERSHIP_DISPUTE // "this is mine and it is legitimate"
}

/// Appeal lifecycle. Filing an appeal never alters the entry — only a reviewed
/// decision can. A SUBMITTED appeal is decided UNDER_REVIEW -> ACCEPTED/REJECTED.
enum RegistryAppealStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

/// A correction / appeal against a PUBLISHED registry entry (PDF §27). Anyone
/// affected can contest a public entry; a compliance reviewer decides. The
/// submitter's contact details are stored privately and never made public.
model RegistryAppeal {
  id                    String               @id @default(uuid()) @db.Uuid
  registryEntryId       String               @db.Uuid
  appealType            RegistryAppealType
  status                RegistryAppealStatus @default(SUBMITTED)
  submitterName         String
  submitterEmail        String
  submitterRelationship String?
  reason                String
  requestedChange       String?
  reviewedByUserId      String?              @db.Uuid
  reviewedAt            DateTime?
  reviewNotes           String?
  resolutionAction      String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  registryEntry RegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@index([registryEntryId])
  @@index([status])
  @@map("registry_appeals")
}

// ────────── Registry Governance — takedown tracking (Phase 3D) ──────────

/// The kind of provider a takedown request is addressed to (PDF §27).
enum TakedownProviderType {
  DOMAIN_REGISTRAR
  HOSTING_PROVIDER
  TELECOM_CARRIER
  EMAIL_PROVIDER
  SOCIAL_PLATFORM
  PAYMENT_PROVIDER
  APP_STORE
  LAW_ENFORCEMENT
  OTHER
}

/// Takedown lifecycle. DRAFT -> SUBMITTED -> ACKNOWLEDGED -> IN_PROGRESS ->
/// COMPLETED / REJECTED; any non-terminal state can be WITHDRAWN.
enum TakedownStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  IN_PROGRESS
  COMPLETED
  REJECTED
  WITHDRAWN
}

/// A request VIGISCAM sends to an external provider asking them to take down
/// the scam infrastructure behind a registry entry (PDF §27). Operational and
/// internal-only — never public. Every status change is written to evidence.
model TakedownRequest {
  id                String               @id @default(uuid()) @db.Uuid
  registryEntryId   String               @db.Uuid
  providerType      TakedownProviderType
  providerName      String
  providerReference String?
  status            TakedownStatus       @default(DRAFT)
  details           String
  submittedByUserId String?              @db.Uuid
  submittedAt       DateTime?
  resolvedByUserId  String?              @db.Uuid
  resolvedAt        DateTime?
  outcomeNotes      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  registryEntry RegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@index([registryEntryId])
  @@index([status])
  @@map("takedown_requests")
}

// ────────── Clustering — signal clusters (Phase 4A) ──────────

/// How a cluster's member signals are related (PDF §32).
enum ClusterMatchType {
  SHARED_INDICATOR
  SHARED_DOMAIN_ROOT
  SHARED_PHONE
  SHARED_EMAIL
  SHARED_WALLET
  SHARED_PHRASE
  SHARED_CATEGORY
  MANUAL
}

/// Cluster lifecycle.
enum ClusterStatus {
  ACTIVE
  MONITORING
  ARCHIVED
}

/// A group of scam signals that share a common indicator or pattern (PDF §32).
/// MVP auto-clustering links signals that share a domain root or email domain;
/// other relationships can be grouped manually by a reviewer. A cluster is the
/// unit that detection-rule suggestions are derived from (Phase 4C).
model ScamCluster {
  id              String           @id @default(uuid()) @db.Uuid
  clusterKey      String           @unique
  matchType       ClusterMatchType
  label           String
  category        String?
  status          ClusterStatus    @default(ACTIVE)
  signalCount     Int              @default(0)
  confidenceScore Int              @default(0)
  firstSeen       DateTime         @default(now())
  lastSeen        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  signals        ScamSignal[]
  detectionRules DetectionRule[]

  @@index([matchType])
  @@index([status])
  @@map("scam_clusters")
}

// ────────── Detection Rules — pattern library (Phase 4B) ──────────

/// What a detection rule matches against (PDF §33).
enum DetectionRuleType {
  PHRASE_MATCH
  INDICATOR_PATTERN
  CATEGORY_RULE
  COMBINED
}

/// Rule lifecycle (PDF §33). A rule is NEVER auto-active — it is created
/// as DRAFT and only an admin can transition it through TESTING -> ACTIVE.
/// DRAFT -> ACTIVE is structurally forbidden (the no-auto-activation gate).
enum DetectionRuleStatus {
  DRAFT
  TESTING
  ACTIVE
  DISABLED
  RETIRED
}

/// A reusable detection rule derived from verified intelligence or authored
/// by a reviewer (PDF §33, §45 DetectionRuleService). Stored and managed
/// here; applying rules to live signals is wired in later phases. Rules are
/// intelligence-only, never a public surface.
model DetectionRule {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  description       String
  ruleType          DetectionRuleType
  pattern           Json
  category          String?
  severity          RiskLevel           @default(MEDIUM)
  status            DetectionRuleStatus @default(DRAFT)
  version           Int                 @default(1)
  sourceClusterId   String?             @db.Uuid
  createdByUserId   String?             @db.Uuid
  activatedByUserId String?             @db.Uuid
  activatedAt       DateTime?
  disabledAt        DateTime?
  retiredAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  cluster ScamCluster? @relation(fields: [sourceClusterId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([ruleType])
  @@map("detection_rules")
}

// ────────── Partner API keys — tenant-scoped auth (Phase 5A) ──────────

/// Capabilities a partner API key can carry (PDF §39 enterprise API keys).
/// AGENCY_FEED (Phase 7C) grants read access to the tenant's agency feeds.
enum PartnerApiKeyScope {
  REPORT_SUBMIT
  READ_TENANT_INTEL
  EVIDENCE_EXPORT
  WEBHOOK_MANAGE
  AGENCY_FEED
}

enum PartnerApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

/// Commercial plan tier (Phase 7E). Controls daily call quota; default FREE.
enum PartnerApiKeyPlan {
  FREE
  PRO
  ENTERPRISE
}

/// A long-lived credential a partner tenant (bank / platform / agency /
/// enterprise) uses to authenticate machine-to-machine calls into VIGISCAM.
/// The raw key is shown exactly ONCE at issuance and never stored — only its
/// SHA-256 hash and a short display prefix are retained. Every authenticated
/// call touches `lastUsedAt`. Internal-only management.
model PartnerApiKey {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @db.Uuid
  keyHash         String                @unique
  keyPrefix       String
  label           String
  scopes          PartnerApiKeyScope[]
  plan            PartnerApiKeyPlan     @default(FREE)
  status          PartnerApiKeyStatus   @default(ACTIVE)
  createdByUserId String?               @db.Uuid
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usage  PartnerApiKeyUsage[]

  @@index([tenantId])
  @@index([status])
  @@map("partner_api_keys")
}

/// Daily request count per partner API key (Phase 7E). The ApiKeyGuard
/// upserts a row keyed on (keyId, date) per authenticated request and rejects
/// further calls when the day's count hits the plan limit.
model PartnerApiKeyUsage {
  id           String   @id @default(uuid()) @db.Uuid
  keyId        String   @db.Uuid
  date         DateTime @db.Date
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  key PartnerApiKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@unique([keyId, date])
  @@index([keyId])
  @@index([date])
  @@map("partner_api_key_usage")
}

// ────────── Outbound webhooks — partner notifications (Phase 5D) ──────────

/// Event types that VIGISCAM delivers to partner-tenant webhooks.
enum WebhookEventType {
  SIGNAL_VERIFIED
  REGISTRY_PUBLISHED
  REGISTRY_UNPUBLISHED
}

enum WebhookSubscriptionStatus {
  ACTIVE
  PAUSED
  REVOKED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
}

/// A partner-tenant subscription to outbound event notifications.
/// The shared HMAC secret is generated server-side, returned to the partner
/// exactly ONCE at creation, and used to sign every delivery so the partner
/// can verify authenticity (Stripe-style scheme).
model WebhookSubscription {
  id              String                    @id @default(uuid()) @db.Uuid
  tenantId        String                    @db.Uuid
  url             String
  secret          String
  eventTypes      WebhookEventType[]
  status          WebhookSubscriptionStatus @default(ACTIVE)
  label           String?
  createdByUserId String?                   @db.Uuid
  revokedAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@index([status])
  @@map("webhook_subscriptions")
}

/// One delivery attempt for a webhook event. Persisted for audit and
/// partner-side debugging.
model WebhookDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  subscriptionId String                @db.Uuid
  tenantId       String                @db.Uuid
  eventType      WebhookEventType
  payload        Json
  signature      String
  attempt        Int                   @default(1)
  status         WebhookDeliveryStatus @default(PENDING)
  responseStatus Int?
  responseBody   String?
  error          String?
  deliveredAt    DateTime?
  succeededAt    DateTime?
  createdAt      DateTime              @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
  @@map("webhook_deliveries")
}

// ────────── Partner evidence export bundles (Phase 5E) ──────────

enum EvidenceExportBundleStatus {
  READY
  EXPIRED
}

/// A frozen snapshot of a tenant's Evidence Vault events, with a SHA-256
/// checksum so the partner can prove integrity to a third party (PDF §39
/// "legal export controls", docs/04 §6). The bundle is computed once at
/// generation time and re-served verbatim on download — never recomputed —
/// so the legal record cannot drift after the fact.
model EvidenceExportBundle {
  id               String                     @id @default(uuid()) @db.Uuid
  tenantId         String                     @db.Uuid
  requestedByKeyId String?                    @db.Uuid
  filters          Json
  recordCount      Int
  checksum         String
  bundle           Json
  status           EvidenceExportBundleStatus @default(READY)
  expiresAt        DateTime?
  createdAt        DateTime                   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("evidence_export_bundles")
}

// ────────── AI decision audit trail (Phase 6A) ──────────

/// Where the AI verdict actually came from.
enum AIDecisionSource {
  STUB
  EXTERNAL
}

/// Every AI call writes one row here (PDF non-negotiable #13 "every AI
/// decision must be versioned and traceable"). The input is captured as a
/// SHA-256 digest (privacy + dedup) plus a truncated snippet for debugging;
/// the output is captured verbatim along with the model version that produced
/// it so verdicts remain reproducible and auditable.
model AIDecision {
  id           String           @id @default(uuid()) @db.Uuid
  serviceKind  String
  modelVersion String
  source       AIDecisionSource @default(STUB)
  entityType   String?
  entityId     String?
  inputDigest  String
  inputSnippet String?
  output       Json
  confidence   Int?
  durationMs   Int?
  error        String?
  createdAt    DateTime         @default(now())

  @@index([serviceKind])
  @@index([entityType, entityId])
  @@index([modelVersion])
  @@index([createdAt])
  @@map("ai_decisions")
}

// ────────── Vector embeddings + similarity (Phase 6B) ──────────

/// A signal's text embedding (PDF §32 "embeddings-based similarity"). MVP
/// storage is a Postgres `real[]` (Prisma Float[]) — fine for thousands of
/// signals; a pgvector / external vector DB swap is a production hardening
/// when the corpus scales.
model SignalEmbedding {
  id           String           @id @default(uuid()) @db.Uuid
  signalId     String           @unique @db.Uuid
  modelVersion String
  source       AIDecisionSource @default(STUB)
  vector       Float[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  signal ScamSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([modelVersion])
  @@map("signal_embeddings")
}

/// A symmetric similarity link between two signals at a given model version.
/// Always stored with `signalAId < signalBId` lexicographically so each pair
/// is canonical and `(signalAId, signalBId, modelVersion)` can be unique.
model SignalSimilarity {
  id           String   @id @default(uuid()) @db.Uuid
  signalAId    String   @db.Uuid
  signalBId    String   @db.Uuid
  score        Float
  modelVersion String
  createdAt    DateTime @default(now())

  signalA ScamSignal @relation("SimilarityA", fields: [signalAId], references: [id], onDelete: Cascade)
  signalB ScamSignal @relation("SimilarityB", fields: [signalBId], references: [id], onDelete: Cascade)

  @@unique([signalAId, signalBId, modelVersion])
  @@index([signalAId])
  @@index([signalBId])
  @@index([score])
  @@map("signal_similarities")
}

// ────────── Identity Collision Graph (Phase 6C) ──────────

/// Kinds of node in the fraud network graph (PDF §32 advanced, Identity
/// Collision Graph). MVP only materialises INDICATOR nodes from scam signals;
/// CAMPAIGN / ACTOR remain in the enum for forward compatibility.
enum FraudGraphNodeType {
  INDICATOR
  CAMPAIGN
  ACTOR
}

/// Why two nodes are linked. MVP edge types are all symmetric, so each edge
/// is stored once with `sourceNodeId < targetNodeId` lexicographically.
/// CAMPAIGN_MEMBERSHIP (Phase 7B) links an INDICATOR node to a CAMPAIGN node.
enum FraudGraphEdgeType {
  CO_OCCURRENCE_CLUSTER
  SIMILAR_TEXT
  SHARED_CATEGORY
  CAMPAIGN_MEMBERSHIP
}

/// A node in the Identity Collision Graph. Each unique
/// (indicatorType, normalizedIndicator) pair becomes one node — repeated
/// signals on the same indicator only update aggregates.
model FraudGraphNode {
  id                  String             @id @default(uuid()) @db.Uuid
  nodeType            FraudGraphNodeType @default(INDICATOR)
  indicatorType       IndicatorType?
  normalizedIndicator String?
  label               String
  category            String?
  signalCount         Int                @default(0)
  riskScore           Int                @default(0)
  firstSeen           DateTime           @default(now())
  lastSeen            DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  outgoingEdges FraudGraphEdge[] @relation("EdgeSource")
  incomingEdges FraudGraphEdge[] @relation("EdgeTarget")

  @@unique([indicatorType, normalizedIndicator])
  @@index([nodeType])
  @@index([category])
  @@index([riskScore])
  @@map("fraud_graph_nodes")
}

/// A weighted, symmetric edge between two graph nodes. Stored once per
/// canonical pair `(source < target, edgeType)`.
model FraudGraphEdge {
  id            String             @id @default(uuid()) @db.Uuid
  sourceNodeId  String             @db.Uuid
  targetNodeId  String             @db.Uuid
  edgeType      FraudGraphEdgeType
  weight        Float              @default(1)
  evidenceCount Int                @default(1)
  firstSeen     DateTime           @default(now())
  lastSeen      DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  sourceNode FraudGraphNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode FraudGraphNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, edgeType])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([edgeType])
  @@map("fraud_graph_edges")
}

// ────────── Authenticity Verification Suite (Phase 6D) ──────────

/// Which authenticity check produced the verdict (PDF §51 Brand Hierarchy
/// "Authenticity Verification Suite").
enum AuthenticityCheckType {
  LIVE_FACE_SEAL
  VOICE_MATCH_SEAL
  SCENE_SEAL
  CAM_VIGUARD
  DUAL_AUTH
  ANTI_FAKE_VIDEO
}

enum AuthenticityResult {
  PASS
  FAIL
  INCONCLUSIVE
}

/// A verdict from one of the Authenticity Verification Suite engines attached
/// to a monitored session (PDF §42 "Individual" / §43 "deepfake/caller
/// authenticity integration"). MVP integration is contract-only — the
/// external Python services slot in via AI_SERVICE_URL; an in-process stub
/// satisfies the contract for dev / CI. Every check writes an AIDecision row
/// alongside this verdict.
model AuthenticityCheck {
  id              String                @id @default(uuid()) @db.Uuid
  sessionId       String                @db.Uuid
  checkType       AuthenticityCheckType
  result          AuthenticityResult
  score           Int
  modelVersion    String
  source          AIDecisionSource      @default(STUB)
  metadata        Json?
  requestedByUserId String?             @db.Uuid
  createdAt       DateTime              @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([checkType])
  @@index([result])
  @@map("authenticity_checks")
}

// ────────── Fraud Journey + VictimState + Risk Fusion v2 (Phase 6E) ──────────

/// Where the user appears to be in the scam journey (PDF §44 fraud-journey).
enum FraudJourneyStage {
  INITIAL_CONTACT
  TRUST_BUILDING
  INFORMATION_GATHERING
  URGENCY_INJECTION
  PAYMENT_REQUEST
  COMPLETED
  INTERVENED
}

/// The user's inferred emotional state during a session (PDF §44 victim-state).
enum VictimStateLabel {
  CALM
  CONFUSED
  PRESSURED
  TRUSTING
  ALARMED
  COMPROMISED
}

/// What the scammer is most likely to do next (PDF §44 predicted-next-move).
enum PredictedAction {
  REQUEST_PAYMENT
  REQUEST_REMOTE_ACCESS
  REQUEST_GIFT_CARD
  REQUEST_PERSONAL_INFO
  ESCALATE_URGENCY
  DROP_OFF
}

model FraudJourneyAssessment {
  id           String            @id @default(uuid()) @db.Uuid
  sessionId    String            @db.Uuid
  stage        FraudJourneyStage
  confidence   Int
  modelVersion String
  source       AIDecisionSource  @default(STUB)
  evidence     Json?
  createdAt    DateTime          @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([stage])
  @@map("fraud_journey_assessments")
}

model VictimStateAssessment {
  id           String           @id @default(uuid()) @db.Uuid
  sessionId    String           @db.Uuid
  state        VictimStateLabel
  confidence   Int
  modelVersion String
  source       AIDecisionSource @default(STUB)
  signals      Json?
  createdAt    DateTime         @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([state])
  @@map("victim_state_assessments")
}

model PredictedNextMove {
  id           String           @id @default(uuid()) @db.Uuid
  sessionId    String           @db.Uuid
  action       PredictedAction
  confidence   Int
  modelVersion String
  source       AIDecisionSource @default(STUB)
  rationale    String?
  createdAt    DateTime         @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([action])
  @@map("predicted_next_moves")
}

/// The unified Risk Fusion v2 score (PDF §45 RiskFusionService). Combines the
/// existing live risk score with fraud-journey stage, victim-state, predicted
/// next move, and authenticity-failure penalty. The full breakdown is stored
/// so the score remains explainable (PDF non-negotiable #8).
model RiskFusionAssessment {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String   @db.Uuid
  fusedScore   Int
  fusedLevel   RiskLevel
  breakdown    Json
  fusedVersion String
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([fusedLevel])
  @@map("risk_fusion_assessments")
}

// ────────── Safe OSINT enrichment (Phase 6F) ──────────

/// Public-source OSINT enrichments attached to an indicator or signal
/// (PDF §44 osint, docs/02 Phase 6 "safe OSINT enrichment"). "Safe" means
/// public-only data — never PII. The actual upstream is contract-only;
/// AI_SERVICE_URL swaps in real providers, an in-process stub satisfies the
/// contract for dev / CI.
model OsintEnrichment {
  id                  String           @id @default(uuid()) @db.Uuid
  signalId            String?          @db.Uuid
  indicatorType       IndicatorType
  normalizedIndicator String
  provider            String
  modelVersion        String
  source              AIDecisionSource @default(STUB)
  data                Json
  riskHints           String[]
  createdAt           DateTime         @default(now())

  signal ScamSignal? @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@unique([indicatorType, normalizedIndicator, provider])
  @@index([signalId])
  @@index([indicatorType, normalizedIndicator])
  @@map("osint_enrichments")
}

// ────────── Cross-border agency feeds (Phase 7C) ──────────

enum AgencyFeedStatus {
  ACTIVE
  PAUSED
  REVOKED
}

/// A cross-border agency intelligence feed (PDF §43 "cross-border agency
/// feeds"; docs/02 Phase 7). Owned by an AGENCY-type tenant; consumed via a
/// partner API key carrying the AGENCY_FEED scope. The feed lists PUBLISHED
/// registry entries that match its filters (categories, indicator types).
/// `region` is a label for the consuming jurisdiction and is recorded for
/// audit / data-sharing-agreement traceability — relevance filtering on
/// entry geography is a future enhancement.
model AgencyFeed {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @db.Uuid
  name            String
  region          String?
  categories      String[]
  indicatorTypes  IndicatorType[]
  status          AgencyFeedStatus @default(ACTIVE)
  createdByUserId String?          @db.Uuid
  lastDeliveredAt DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries AgencyFeedDelivery[]

  @@index([tenantId])
  @@index([status])
  @@index([region])
  @@map("agency_feeds")
}

/// One feed-consumption event — captured per fetch for the chain-of-custody
/// audit required by cross-border data-sharing agreements (docs/04 LR-4).
model AgencyFeedDelivery {
  id               String    @id @default(uuid()) @db.Uuid
  feedId           String    @db.Uuid
  tenantId         String    @db.Uuid
  requestedByKeyId String?   @db.Uuid
  itemCount        Int
  sinceCursor      DateTime?
  untilCursor      DateTime
  createdAt        DateTime  @default(now())

  feed AgencyFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([feedId])
  @@index([tenantId])
  @@map("agency_feed_deliveries")
}

// ────────── Advanced takedown automation (Phase 7D) ──────────

/// A reusable template mapping a provider (by OSINT-detected name) to its
/// abuse-handling contact + a request-details boilerplate (PDF §43 "advanced
/// takedown automation"). When a registry entry is PUBLISHED the automation
/// looks up matching enabled templates and auto-drafts a TakedownRequest —
/// always as DRAFT, so a reviewer still inspects and submits.
model TakedownProviderTemplate {
  id              String               @id @default(uuid()) @db.Uuid
  providerType    TakedownProviderType
  providerName    String
  /// Case-insensitive regex matched against OSINT-returned registrar / host name.
  detectorPattern String
  abuseContact    String?
  /// Boilerplate with `{indicator}`, `{category}`, `{summary}` placeholders.
  detailsTemplate String
  enabled         Boolean              @default(true)
  priority        Int                  @default(0)
  createdByUserId String?              @db.Uuid
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([providerType, providerName])
  @@index([enabled])
  @@map("takedown_provider_templates")
}

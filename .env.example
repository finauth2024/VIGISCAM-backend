# ─────────────────────────────────────────────────────────────
# VIGISCAM Backend — environment template
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# In Azure, these are sourced from Azure Key Vault, not files.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL (Azure Database for PostgreSQL in cloud envs)
# Local example uses a Postgres on localhost:5432.
DATABASE_URL=postgresql://vigiscam:vigiscam@localhost:5432/vigiscam?schema=public

# Redis (Phase 1+: sessions, rate-limit store, queues). Optional in Phase 0.
REDIS_URL=redis://localhost:6379

# CORS — comma-separated allowed origins (the Vercel frontend origins)
CORS_ORIGINS=http://localhost:3001,https://vigiscam.vercel.app

# API docs
SWAGGER_ENABLED=true

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Rate limiting (global default; per-route overrides come later)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
